
  int piezoPin = 9;
int potPin = A0;
int butonPin = 2;
int ledPin = 3;

// Melodi
int notalar[] = {262, 294, 330, 349, 392};
int sureler[] = {300, 300, 300, 300, 300};
int notaSayisi = 5;

void setup() {
  pinMode(piezoPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(butonPin, INPUT_PULLUP);
}

void loop() {
  // Sistem sadece butona basıldığında çalışsın
  if (digitalRead(butonPin) == LOW) {
    
    // Potansiyometre değerini okuyup 100-5000 arasına çeviriyoruz
    int potDeger = analogRead(potPin);
    int frekans = map(potDeger, 0, 1023, 100, 5000);
    
    // Melodi döngüsü
    for (int i = 0; i < notaSayisi; i++) {
      digitalWrite(ledPin, HIGH);
      
      // Notalara potansiyometreden gelen frekansı ekliyoruz ki ses değişsin
      tone(piezoPin, notalar[i] + frekans);
      delay(sureler[i]);
      
      digitalWrite(ledPin, LOW);
      delay(50);
    }
  } else {
    // Butona basılmıyorsa sessiz kal
    noTone(piezoPin);
  }
}
